const LOCALES: Record<string, TranslationMap> = {
  'zh_CN': ZH_CN,
  'en_US': EN_US,
};

let currentLocale: string = 'zh_CN';

export function initI18n(): void {
  let systemLocale: string = i18n.System.getSystemLocale();
  if (systemLocale.startsWith('zh')) {
    currentLocale = 'zh_CN';
  } else {
    currentLocale = 'en_US';
  }
}

export function setAppLocale(locale: string): void {
  currentLocale = locale;
}

export function getAppLocale(): string {
  return currentLocale;
}

export function t(key: string, ...args: string[]): string {
  let map: TranslationMap | undefined = LOCALES[currentLocale];
  if (map === undefined || map === null) {
    map = ZH_CN;
  }
  let value: string | undefined = map[key];
  if (value === undefined || value === null) {
    value = ZH_CN[key];
  }
  if (value === undefined || value === null) {
    return key;
  }
  let result: string = value;
  for (let i: number = 0; i < args.length; i++) {
    result = result.replace(`{${i}}`, args[i]);
  }
  return result;
}
